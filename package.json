{
  "name": "react_native_form",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "node:clean": "rm -rf $TMPDIR/react-* && rm -rf ios/build/ModuleCache/* && rm -rf node_modules/ && rm -rf package-lock.json && rm -rf yarn.lock && npm cache clean -force && yarn",
    "android:clean": "cd android && ./gradlew clean && cd ..",
    "ios:pod-clean": "cd ios && rm -rf Pods && rm -rf Podfile.lock && pod install --repo-update && cd ..",
    "ios:pod": "pod install --project-directory=ios",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios:run": "react-native run-ios --simulator \"iPhone 15\"",
    "lint": "eslint .",
    "start": "react-native start --reset-cache",
    "test": "jest",
    "update-snapshots": "jest -u",
    "e2e:build-ios-debug": "detox build -c ios.sim.debug",
    "e2e:build-ios-release": "detox build -c ios.sim.release",
    "e2e:test-ios-debug": "detox test -c ios.sim.debug",
    "e2e:test-ios-release": "detox test -c ios.sim.release",
    "e2e:build-android-debug": "yarn android:clean && detox build -c android.emu.debug",
    "e2e:build-android-release": "yarn android:clean && detox build -c android.emu.release",
    "e2e:test-android-debug": "detox test -c android.emu.debug",
    "e2e:test-android-release": "detox test -c android.emu.release"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "react": "18.2.0",
    "react-hook-form": "^7.51.3",
    "react-native": "0.73.7",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-safe-area-context": "^4.5.3",
    "react-native-screens": "^3.20.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/preset-react": "^7.26.3",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.6.3",
    "detox": "^20.34.0",
    "eslint": "^8.19.0",
    "jest": "^29",
    "jest-watch-typeahead": "^2.2.2",
    "prettier": "2.8.8",
    "react-test-renderer": "18.2.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "watchPlugins": [
    "jest-watch-typeahead/filename",
    "jest-watch-typeahead/testname"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
